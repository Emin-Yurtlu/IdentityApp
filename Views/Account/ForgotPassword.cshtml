@{
    ViewData["Title"] = "Şifre Sıfırla";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 400px; border-radius: 12px;">
        <div class="card-body p-4 text-center">
            <h4 class="fw-bold text-primary mb-3">Şifremi Unuttum</h4>
            
            @if (TempData["message"] != null)
            {
                <div class="alert alert-light border-0 small py-2">@TempData["message"]</div>
            }

            <form asp-action="ForgotPassword" method="post" class="text-start">
                <div class="mb-3">
                    <label for="Email" class="form-label small fw-semibold">E-Posta Adresiniz</label>
                    <input name="Email" type="email" class="form-control form-control-sm" required>
                </div>
                <button type="submit" class="btn btn-primary w-100 rounded-pill">Sıfırlama Bağlantısı Gönder</button>
            </form>
            
            <div class="mt-3">
                <a asp-action="Login" class="small text-decoration-none text-muted">Giriş Ekranına Dön</a>
            </div>
        </div>
    </div>
</div>