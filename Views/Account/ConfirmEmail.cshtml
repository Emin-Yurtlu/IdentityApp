@{
    ViewData["Title"] = "Email Doğrulama";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Email Onay Durumu</h4>
                </div>
                <div class="card-body text-center">
                    
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success mt-3" role="alert">
                            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                        </div>
                        <p class="mt-3">Artık hesabınıza giriş yapabilirsiniz.</p>
                        <a href="/Account/Login" class="btn btn-success">Giriş Yap</a>
                    }
                    else if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                        </div>
                        <p class="mt-3">Bir sorun oluştu. Lütfen bağlantınızı kontrol edin veya destekle iletişime geçin.</p>
                        <a href="/" class="btn btn-secondary">Ana Sayfaya Dön</a>
                    }
                    else
                    {
                        <div class="alert alert-info mt-3">
                            Lütfen bekleyiniz, işleminiz kontrol ediliyor...
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>