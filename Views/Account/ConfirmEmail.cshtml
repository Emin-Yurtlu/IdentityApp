@{
    ViewData["Title"] = "Onay";
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm border-0 mx-auto p-4" style="max-width: 400px; border-radius: 15px;">
        <h2 class="h4 mb-3">Hesap Onayı</h2>
        
        @if (TempData["message"] != null)
        {
            <div class="alert alert-light border-0 small">
                @TempData["message"]
            </div>
        }

        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm rounded-pill px-4">
            Giriş Sayfasına Git
        </a>
    </div>
</div>