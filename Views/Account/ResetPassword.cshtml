@model ResetPasswordModel

@{
    ViewData["Title"] = "Şifre Yenileme";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 400px; border-radius: 12px;">
        <div class="card-body p-4">
            <h4 class="text-center fw-bold text-primary mb-4">Şifre Sıfırla</h4>

            <form asp-action="ResetPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <input type="hidden" asp-for="Token" />

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-semibold">E-Posta</label>
                    <input asp-for="Email" class="form-control form-control-sm" />
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label small fw-semibold">Yeni Şifre</label>
                    <input asp-for="Password" type="password" class="form-control form-control-sm" />
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label small fw-semibold">Şifre Tekrar</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control form-control-sm" />
                </div>

                <button type="submit" class="btn btn-primary w-100 rounded-pill">Güncelle</button>
            </form>
        </div>
    </div>
</div>