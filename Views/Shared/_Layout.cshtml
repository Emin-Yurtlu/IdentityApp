<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] -IDENTITY</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-journal-text"></i> IDENTITY
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var isAdmin = User.Claims.Any(c => c.Type == System.Security.Claims.ClaimTypes.Role && c.Value.Trim().ToLower() == "admin");
                            if (isAdmin)
                            {
                                <li class="nav-item"><a class="nav-link small fw-semibold" asp-controller="Users" asp-action="Index">Kullanıcılar</a></li>
                                <li class="nav-item"><a class="nav-link small fw-semibold" asp-controller="Roles" asp-action="Index">Roller</a></li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-3"><span class="text-muted small">@User.Identity.Name</span></li>
                            <li class="nav-item"><a class="btn btn-outline-danger btn-sm rounded-pill" asp-controller="Account" asp-action="Logout">Çıkış</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link small" asp-controller="Account" asp-action="Login">Giriş</a></li>
                            <li class="nav-item ms-2"><a class="btn btn-primary btn-sm rounded-pill px-3" asp-controller="Account" asp-action="Create">Kayıt Ol</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["message"] != null)
        {
            <div class="alert alert-info border-0 shadow-sm small alert-dismissible fade show" role="alert">
                @TempData["message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top bg-white py-3 text-center mt-auto">
        <div class="container small text-muted">
            &copy; 2026 - BlogApp - <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Gizlilik</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>