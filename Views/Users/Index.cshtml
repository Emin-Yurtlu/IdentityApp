@model IEnumerable<AppUser>

@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-primary mb-0">Kullanıcı Listesi</h4>
        <a class="btn btn-primary btn-sm rounded-pill px-4" asp-controller="Account" asp-action="Create">
            <i class="bi bi-person-plus"></i> Yeni Kullanıcı
        </a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px;">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light small">
                    <tr>
                        <th class="ps-4">Ad Soyad</th>
                        <th>E-Posta</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="small">
                    @if (!Model.Any())
                    {
                        <tr><td colspan="3" class="text-center py-4 text-muted">Kayıtlı kullanıcı bulunamadı.</td></tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@user.FullName</td>
                                <td>@user.Email</td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm rounded-pill py-0">Düzenle</a>
                                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-outline-danger btn-sm rounded-pill py-0">Sil</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>