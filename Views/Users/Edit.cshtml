@model EditViewModel

@{
    ViewData["Title"] = "Kullanıcı Düzenle";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 500px; border-radius: 12px;">
        <div class="card-body p-4">
            <h4 class="text-center fw-bold text-primary mb-4">Kullanıcıyı Güncelle</h4>

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label small fw-semibold">Ad Soyad</label>
                    <input asp-for="FullName" class="form-control form-control-sm bg-light" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-semibold">E-Posta</label>
                    <input asp-for="Email" class="form-control form-control-sm bg-light" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col">
                        <label asp-for="Password" class="form-label small fw-semibold">Yeni Şifre</label>
                        <input asp-for="Password" type="password" class="form-control form-control-sm bg-light" />
                    </div>
                    <div class="col">
                        <label asp-for="ConfirmPassword" class="form-label small fw-semibold">Onay</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control form-control-sm bg-light" />
                    </div>
                </div>

                <div class="card border-0 bg-light mb-4" style="border-radius: 8px;">
                    <div class="card-body py-2">
                        <p class="small fw-bold mb-2">Roller</p>
                        @foreach (var role in ViewBag.Roles)
                        {
                            <div class="form-check form-check-inline">
                                <input type="checkbox" class="form-check-input" name="SelectedRoles" value="@role" id="@role"
                                @(Model.SelectedRoles != null && Model.SelectedRoles.Contains(role) ? "checked" : "") />
                                <label for="@role" class="form-check-label small">@role</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill">Değişiklikleri Kaydet</button>
                    <a asp-action="Index" class="btn btn-link btn-sm text-decoration-none text-muted">Listeye Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>