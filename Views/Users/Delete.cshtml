@model DeleteViewModel

@{
    ViewData["Title"] = "Kullanıcı Sil";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 400px; border-radius: 12px;">
        <div class="card-body p-4 text-center">
            <h4 class="fw-bold text-danger mb-3">Kullanıcıyı Sil?</h4>
            <p class="text-muted small mb-4">Bu işlem geri alınamaz. Devam etmek istediğinize emin misiniz?</p>

            <div class="bg-light p-3 rounded-3 mb-4 text-start small">
                <div class="fw-bold text-dark">@Model.FullName</div>
                <div class="text-secondary">@Model.Email</div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger rounded-pill">Evet, Kullanıcıyı Sil</button>
                    <a asp-action="Index" class="btn btn-link btn-sm text-decoration-none text-muted">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>