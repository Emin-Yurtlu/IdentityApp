@model DeleteViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 border-top border-danger border-4 rounded-3">
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-exclamaition-triangle text-danger" style="font-size: 3rem;"></i>
                        <h4 class="fw-bold text-dark mt-3">User Deletion</h4>
                        <p class="text-muted">Are you sure you want to delete this user? This action cannot be undone.</p>
                    </div>

                    <div class="bg-light p-3 rounded-3 mb-4 text-start">
                        <p class="mb-1 small text-muted">User to be deleted:</p>
                        <h6 class="fw-bold mb-0">@Model.FullName</h6>
                        <span class="small text-secondary">@Model.Email</span>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-semibold py-2 shadow-sm">
                                Yes, Delete User
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm py-2">
                                Cancel and Go Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>