@model IEnumerable<AppRole>

@{
    ViewData["Title"] = "Rol Yönetimi";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-primary mb-0">Rol Listesi</h4>
        <a class="btn btn-primary btn-sm rounded-pill px-4" asp-action="Create">
            <i class="bi bi-plus-lg"></i> Yeni Rol
        </a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px;">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light small">
                    <tr>
                        <th class="ps-4">Rol Adı</th>
                        <th>Kullanıcılar</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="small">
                    @if (!Model.Any())
                    {
                        <tr><td colspan="3" class="text-center py-4 text-muted">Henüz bir rol tanımlanmamış.</td></tr>
                    }
                    else
                    {
                        @foreach (var role in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@role.Name</td>
                                <td asp-role-users="@role.Id"></td>
                                <td class="text-end pe-4">
                                    <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="d-inline">
                                        <a class="btn btn-outline-primary btn-sm rounded-pill py-0" asp-action="Edit" asp-route-id="@role.Id">Düzenle</a>
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill py-0" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>