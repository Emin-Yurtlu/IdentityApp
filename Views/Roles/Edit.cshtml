@model AppRole

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 border-top border-primary border-4 rounded-3">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-4">
                        <h4 class="fw-bold text-dark">Edit Role</h4>
                        <p class="text-muted small">Update the role name and permissions</p>
                    </div>

                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                        
                        @* ID bilgisini güvenli bir şekilde taşımak için *@
                        <input type="hidden" asp-for="Id" />

                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control border-0 bg-light" placeholder="Role Name" />
                            <label asp-for="Name">Role Name</label>
                            <span asp-validation-for="Name" class="text-danger x-small"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary fw-semibold py-2 shadow-sm">
                                <i class="bi bi-check2-circle me-1"></i> Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-outline-light btn-sm text-muted border-0">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
  <table class="table table-sm table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Email</th>
                   <th style="width:80px;"></th>
                </tr>
            </thead>
            @if (ViewBag.users!=null)
    {
        @if(ViewBag.Users.Count==0)
            {
                <tr>
                    <td colspan="3" class="text-center">User yok.</td>
                </tr>
			}
			
            
                @foreach (var user in ViewBag.Users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.FullName</td>
                          <td>@user.Email</td>
                       
                        <td>
                           
                               <a asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id" class="btn btn-primary btn-sm">Edit</a>
							
                        </td>
                    </tr>
                }
    }
            
           
        </table>

<style>
    .form-control:focus { 
        background-color: #fff !important; 
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, .10) !important; 
        border: 1px solid #0d6efd !important; 
    }
    .x-small { font-size: 0.75rem; }
    /* Floating label için küçük bir düzeltme */
    .form-floating > label { opacity: .7; }
</style>