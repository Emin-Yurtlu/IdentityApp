@model AppRole

@{
    ViewData["Title"] = "Rol Düzenle";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 mx-auto mb-4" style="max-width: 500px; border-radius: 12px;">
        <div class="card-body p-4 text-center">
            <h4 class="fw-bold text-primary mb-1">Rol Düzenle</h4>
            <p class="text-muted small mb-4">Rol ismini güncelleyebilirsiniz</p>

            <form asp-action="Edit" method="post" class="text-start">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label asp-for="Name" class="form-label small fw-semibold">Rol Adı</label>
                    <input asp-for="Name" class="form-control form-control-sm bg-light" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill">Değişiklikleri Kaydet</button>
                    <a asp-action="Index" class="btn btn-link btn-sm text-decoration-none text-muted">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>

    @if (ViewBag.users != null)
    {
        <div class="card shadow-sm border-0 mx-auto" style="max-width: 800px; border-radius: 12px;">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="bg-light small">
                        <tr>
                            <th class="ps-4">Ad Soyad</th>
                            <th>E-Posta</th>
                            <th class="text-end pe-4">İşlem</th>
                        </tr>
                    </thead>
                    <tbody class="small">
                        @if (ViewBag.Users.Count == 0)
                        {
                            <tr><td colspan="3" class="text-center py-4">Bu role ait kullanıcı bulunamadı.</td></tr>
                        }
                        else
                        {
                            @foreach (var user in ViewBag.Users)
                            {
                                <tr>
                                    <td class="ps-4">@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm rounded-pill py-0">Düzenle</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>